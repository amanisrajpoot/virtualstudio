{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://storyforge.local/schemas/semantic_world/semantic_world.schema.json",
  "title": "StoryForge Semantic World",
  "type": "object",
  "required": ["scene_asset_id", "version", "anchors", "metadata"],
  "additionalProperties": false,
  "properties": {
    "scene_asset_id": {
      "type": "string",
      "pattern": "^scene_[a-z0-9_]+_v[0-9]+$",
      "examples": ["scene_village_market_v1"]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "examples": ["1.0.0"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/semanticAnchor"
      }
    }
  },
  "$defs": {
    "semanticAnchor": {
      "type": "object",
      "required": ["anchor", "display_name", "tags", "metadata"],
      "additionalProperties": false,
      "properties": {
        "anchor": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "examples": ["market_center", "stall_front", "tree_area"]
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "anchorReference": {
      "type": "object",
      "required": ["anchor"],
      "additionalProperties": false,
      "properties": {
        "anchor": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "relation": {
          "type": "string",
          "enum": ["at", "near", "left_of", "right_of", "in_front_of", "behind", "facing"],
          "default": "at"
        },
        "relative_to": {
          "type": ["string", "null"],
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "distance": {
          "type": "string",
          "enum": ["contact", "near", "medium", "far"],
          "default": "near"
        },
        "require_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      }
    }
  }
}
