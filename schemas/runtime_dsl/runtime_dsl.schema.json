{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Runtime DSL",
  "description": "Execution instructions generated by the Director Engine. Format is versioned and track-based.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of the Runtime DSL schema",
      "const": "1.0"
    },
    "scene": {
      "type": "string",
      "description": "The scene asset ID"
    },
    "duration": {
      "type": "number",
      "description": "Total duration of the sequence in seconds"
    },
    "tracks": {
      "type": "object",
      "properties": {
        "actor": {
          "type": "array",
          "description": "Controls movement, animations, dialogue, and state changes.",
          "items": {
            "type": "object",
            "properties": {
              "time": {
                "type": "number",
                "description": "Execution time in seconds from sequence start"
              },
              "actor_id": {
                "type": "string",
                "description": "Actor ID executing the action"
              },
              "action": {
                "type": "string",
                "enum": ["move_to", "look_at_target", "play_animation", "speak", "set_emotion", "set_energy", "pickup", "drop"],
                "description": "Command to call on the actor"
              },
              "target": {
                "type": ["string", "object", "null", "number"],
                "description": "Target argument for the action (e.g., anchor name, reference object, text, or float)"
              },
              "context": {
                "type": "object",
                "description": "Optional additional arguments or metadata for the action"
              }
            },
            "required": ["time", "actor_id", "action"]
          }
        },
        "camera": {
          "type": "array",
          "description": "Controls camera cuts and transitions.",
          "items": {
            "type": "object",
            "properties": {
              "time": {
                "type": "number",
                "description": "Time in seconds to switch camera"
              },
              "preset": {
                "type": "string",
                "description": "Camera preset asset ID"
              },
              "target": {
                "type": ["string", "null"],
                "description": "Optional focus target for the camera"
              }
            },
            "required": ["time", "preset"]
          }
        },
        "audio": {
          "type": "array",
          "description": "Controls sound effects, ambient noise, and music.",
          "items": {
            "type": "object",
            "properties": {
              "time": {
                "type": "number",
                "description": "Time in seconds to play audio"
              },
              "asset_id": {
                "type": "string",
                "description": "Audio asset ID"
              },
              "type": {
                "type": "string",
                "enum": ["sfx", "music", "ambient"],
                "description": "Type of audio"
              },
              "volume_db": {
                "type": "number",
                "description": "Volume offset in decibels",
                "default": 0.0
              }
            },
            "required": ["time", "asset_id", "type"]
          }
        },
        "effects": {
          "type": "array",
          "description": "Controls visual effects and environment overrides.",
          "items": {
            "type": "object",
            "properties": {
              "time": {
                "type": "number",
                "description": "Time in seconds to trigger effect"
              },
              "asset_id": {
                "type": "string",
                "description": "Effect asset ID"
              },
              "anchor": {
                "type": ["string", "null"],
                "description": "Optional anchor point where the effect spawns"
              },
              "duration": {
                "type": "number",
                "description": "Optional duration of the effect. If 0, it may be a one-shot particle."
              }
            },
            "required": ["time", "asset_id"]
          }
        }
      },
      "required": ["actor", "camera", "audio", "effects"]
    }
  },
  "required": ["schema_version", "scene", "duration", "tracks"]
}
